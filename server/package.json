{
  "name": "internhub",
  "version": "1.0.0",
  "description": "Server for internhub app",
  "main": "server.js",
  "scripts": {
    "test": "npm run test",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:push": "drizzle-kit push",
    "db:seed": "node src/db/seed.js",
    "db:crash": "chmod +x db-reset.sh && ./db-reset.sh",
    "db:refresh": "npm run db:crash && npm run db:push && npm run db:seed"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.11"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "resend": "^6.9.2",
    "zod": "^4.3.6"
  }
}
